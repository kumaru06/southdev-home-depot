# .env.example
# Copy this to .env and fill in your values
# OR manually update config/config.php and config/database.php

# ========================================
# APPLICATION CONFIGURATION
# ========================================

APP_NAME=SouthDev Home Depot
APP_URL=https://yourdomain.com
APP_ENV=production
APP_DEBUG=false

# ========================================
# DATABASE CONFIGURATION
# ========================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=southdev_home_depot
DB_USER=southdev_user
DB_PASSWORD=your_secure_password_here

# ========================================
# PAYMENT GATEWAY CONFIGURATION
# ========================================

# GCash E-wallet
GCASH_PHONE=0917-XXX-XXXX
GCASH_NAME=SouthDev Home Depot

# Bank Transfer
BANK_NAME=BDO
BANK_ACCOUNT=1234-5678-9012
BANK_BRANCH=Davao City

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=SouthDev Home Depot

# ========================================
# SECURITY CONFIGURATION
# ========================================

SESSION_TIMEOUT=3600
CSRF_TOKEN_EXPIRY=3600
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================

MAX_UPLOAD_SIZE=5242880  # 5MB in bytes
ALLOWED_IMAGE_TYPES=jpeg,jpg,png,gif
UPLOAD_PATH=assets/uploads

# ========================================
# PAGINATION & LIMITS
# ========================================

PRODUCTS_PER_PAGE=12
ORDERS_PER_PAGE=25
LOGS_PER_PAGE=25
CART_MAX_QUANTITY=999

# ========================================
# TIMEZONE
# ========================================

TIMEZONE=Asia/Manila
