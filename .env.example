# ========================================
# SouthDev Home Depot – Environment Config
# ========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Application ──
APP_NAME="Southdev Home Depot"
APP_TAGLINE="Davao City's Premier Tiles & Hardware Supply"
APP_URL=http://localhost/southdev-home-depot
APP_VERSION=1.0.0
APP_ENV=local
APP_DEBUG=true
APP_LOCATION="Davao City, Philippines"
TIMEZONE=Asia/Manila

# ── Database ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=southdev
DB_USER=root
DB_PASSWORD=

# ── PayMongo (get keys from https://dashboard.paymongo.com/settings/api-keys) ──
PAYMONGO_ENABLED=true
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whk_test_xxxxxxxxxxxxx

# ── Email (SMTP) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=your-email@gmail.com
MAIL_FROM_NAME="Southdev Home Depot"

# ── Google Maps (optional) ──
APP_MAP_LAT=
APP_MAP_LNG=
APP_GOOGLE_MAPS_API_KEY=
