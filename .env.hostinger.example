# Copy to .env on Hostinger (public_html/.env) after creating MySQL database in hPanel

APP_NAME="Southdev Home Depot"
APP_TAGLINE="Davao City's Premier Tiles & Hardware Supply"
APP_URL=https://southdevhomedepotdavao.com
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false
APP_LOCATION="Davao City, Philippines"
TIMEZONE=Asia/Manila

# Fill in from hPanel → Websites → Manage → Databases → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_NAME=REPLACE_WITH_HOSTINGER_DB_NAME
DB_USER=REPLACE_WITH_HOSTINGER_DB_USER
DB_PASSWORD=REPLACE_WITH_HOSTINGER_DB_PASSWORD

# Copy from your InfinityFree .env if you had these configured
PAYMONGO_ENABLED=true
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=
MAIL_FROM_NAME="Southdev Home Depot"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://southdevhomedepotdavao.com/google-callback
