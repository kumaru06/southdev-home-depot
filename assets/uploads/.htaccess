Options -Indexes

# Uploaded files must never execute as code.
<FilesMatch "\.(php|php[0-9]?|phtml|phar|cgi|pl|asp|aspx|jsp|sh|bat|cmd|ps1)$">
    Require all denied
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>